{
  "name": "@VIA-Labs-Tech/networks",
  "version": "0.0.1",
  "description": "Single source of truth for all VIA chain data, contract deployments, and RPC endpoints",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx src/scripts/generate-registry.ts && tsup",
    "test": "vitest run",
    "generate-registry": "tsx src/scripts/generate-registry.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VIA-Labs-Tech/networks.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
