{
  "name": "@brad-za/networks",
  "version": "0.0.3",
  "description": "Single source of truth for all VIA chain data, contract deployments, and RPC endpoints",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx src/scripts/generate-registry.ts && tsup",
    "test": "vitest run",
    "generate-registry": "tsx src/scripts/generate-registry.ts",
    "prepublishOnly": "npm run build",
    "patch": "npm version patch",
    "push-patch": "git push --follow-tags"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brad-za/via-networks.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
